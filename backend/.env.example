# ╔══════════════════════════════════════════════════════════════╗
# ║  AI RAG Chatbot — Environment Configuration                ║
# ║  Copy this file to .env and fill in your values             ║
# ╚══════════════════════════════════════════════════════════════╝

# ── App ───────────────────────────────────────────────────────
APP_NAME="AI RAG Chatbot"
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# ── JWT Auth ──────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database (Docker Compose default) ────────────────────────
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@localhost:5432/ragdb
DATABASE_SYNC_URL=postgresql://raguser:ragpass@localhost:5432/ragdb

# ── AI Provider ──────────────────────────────────────────────
# Options: openai | azure | custom
AI_PROVIDER=openai

# OpenAI (default)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Azure OpenAI (if AI_PROVIDER=azure)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ── Embeddings / Chunking ────────────────────────────────────
EMBEDDING_DIMENSION=1536
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# ── Storage ──────────────────────────────────────────────────
# Options: local | azure_blob
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage

# Azure Blob (if STORAGE_BACKEND=azure_blob)
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=documents

# ── Upload ───────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=20
